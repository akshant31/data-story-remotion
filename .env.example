# Voiceover provider API keys
# Copy this file to .env and fill in your real keys.

# Sarvam (default provider) — Indian-accent English / Hinglish
SARVAM_API_KEY=

# Optional Sarvam settings
# VO_PROVIDER=sarvam
# VO_VOICE=shubh
# VO_LANG=en-IN
# VO_PACE=1
# VO_FORMAT=wav

# Alternative providers (uncomment and set one to switch)
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=
